/* =============================================================================
 * COLOR PALETTE — Strict Black & White
 * ============================================================================= */
@define-color bg_transparent transparent;
@define-color bg_base #ffffff; /* pill background: pure white */
@define-color bg_module #f0f0f0; /* light gray for accented modules */
@define-color bg_hover #e0e0e0; /* hover state gray */
@define-color text_main #000000; /* pure black text */
@define-color text_light #000000;
@define-color text_muted #808080; /* mid-gray for disabled/muted items */
@define-color accent #000000; /* pure black for highest contrast */
@define-color accent_alt #333333; /* dark gray for secondary accents */
@define-color warning #555555; /* mid-dark gray for warnings */
@define-color critical #000000; /* pure black for critical alerts */
@define-color border_color #cccccc; /* soft grayscale border */

/* =============================================================================
 * BASE STYLES
 * ============================================================================= */
* {
  border: none;
  border-radius: 0;
  font-family: "JetBrainsMono Nerd Font", monospace;
  font-weight: bold;
  font-size: 12px;
  min-height: 0;
  transition:
    background-color 0.3s ease,
    color 0.3s ease,
    margin 0.3s ease;
}

window#waybar {
  background-color: @bg_transparent;
  color: @text_light;
  padding: 2px 12px;
  margin: 6px 120px; /* Added 6px margin to top and bottom */
}

/* =============================================================================
 * JOINED MODULES (The Pill Layout Base)
 * ============================================================================= */
.modules-left > widget > *,
.modules-center > widget > *,
.modules-right > widget > *,
#group-tray-expander > widget > * {
  background-color: @bg_base;
  color: @text_main;
  border-top: 1px solid @border_color;
  border-bottom: 1px solid @border_color;
  border-right: 1px solid @border_color;
  border-left: none;
  border-radius: 0;
  padding: 2px 8px;
  margin: 1px 0;
}

/* First child caps the left side */
.modules-left > widget:first-child > *,
.modules-center > widget:first-child > *,
.modules-right > widget:first-child > *,
#group-tray-expander > widget:first-child > * {
  border-left: 1px solid @border_color;
  border-top-left-radius: 8px;
  border-bottom-left-radius: 8px;
}

/* Last child caps the right side */
.modules-left > widget:last-child > *,
.modules-center > widget:last-child > *,
.modules-right > widget:last-child > *,
#group-tray-expander > widget:last-child > * {
  border-top-right-radius: 8px;
  border-bottom-right-radius: 8px;
}

/* =============================================================================
 * TASKBAR
 * ============================================================================= */
window#waybar #taskbar button {
  padding: 0px 4px;
  margin: 0;
  background-color: transparent;
  color: #ffffff;
  border-radius: 4px;
}

window#waybar #taskbar button:hover {
  background-color: transparent;
  color: #000000;
}

window#waybar #taskbar button.active {
  color: #000000;
  font-weight: bold;
}

/* =============================================================================
 * MODULE SPECIFICS & STATES
 * ============================================================================= */
#clock {
  background-color: @bg_module;
  color: @accent;
  font-weight: 800;
}

#pulseaudio.muted {
  color: @warning;
  background-color: @bg_module;
}

#network {
  color: @accent_alt;
}

#network.disconnected {
  color: @critical;
}

#bluetooth.connected {
  color: @accent_alt;
}

#bluetooth.off,
#bluetooth.disabled {
  color: @text_muted;
}

#backlight {
  color: @text_main;
}

#battery {
  color: @text_main;
}

#battery.charging {
  background-color: @bg_hover;
  color: @accent_alt;
}

#battery.warning:not(.charging) {
  color: @warning;
}

#battery.critical:not(.charging) {
  color: @critical;
  animation-name: warning-pulse;
  animation-duration: 1s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

/* =============================================================================
 * TRAY, EXPANDER & POWER
 * ============================================================================= */
#tray {
  padding: 0 10px;
}

#custom-expand-icon {
  color: @text_muted;
  padding: 2px 6px;
}

#custom-expand-icon:hover {
  color: @text_main;
  background-color: @bg_hover;
}

#custom-power {
  background-color: @critical;
  color: @bg_base;
  padding-right: 14px;
}

#custom-power:hover {
  background-color: @bg_base;
  color: @accent;
  box-shadow: 0 0 5px rgba(0, 0, 0, 0.4);
}

/* =============================================================================
 * GLOBAL HOVER EFFECTS
 * ============================================================================= */
#pulseaudio:hover,
#network:hover,
#bluetooth:hover,
#battery:hover,
#clock:hover,
#cpu:hover,
#memory:hover,
#backlight:hover,
#custom-timer:hover {
  background-color: @bg_hover;
  box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.15);
}

/* =============================================================================
 * CUSTOM TIMER STATES
 * ============================================================================= */
#custom-timer {
  font-weight: bold;
}

#custom-timer.disabled {
  background-color: @bg_base;
  color: @text_muted;
  opacity: 0.6;
}

#custom-timer.idle {
  background-color: @bg_base;
  color: @text_muted;
}

#custom-timer.select {
  background-color: @bg_module;
  color: @accent_alt;
}

#custom-timer.running {
  background-color: @bg_base;
  color: @accent;
}

#custom-timer.pomo_break {
  background-color: @bg_module;
  color: @accent_alt;
}

#custom-timer.pomo_msg {
  background-color: @bg_base;
  color: @text_main;
}

#custom-timer.paused {
  background-color: @bg_hover;
  color: @accent;
}

#custom-timer.warning {
  background-color: @bg_base;
  color: @warning;
  animation-name: warning-pulse;
  animation-duration: 1s;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
  animation-direction: alternate;
}

#custom-timer.done {
  background-color: @accent;
  color: @bg_base;
}

#custom-timer.reset {
  background-color: @bg_base;
  color: @warning;
}

/* =============================================================================
 * KEYFRAMES
 * ============================================================================= */
@keyframes warning-pulse {
  0% {
    color: @critical;
    opacity: 1;
  }
  100% {
    color: @critical;
    opacity: 0.4;
  }
}
